{
  "planVersion": "1.0.0",
  "project": "GameRewritten",
  "scope": "vertical-slice",
  "coverageGoal": "full-game-audio eventually; this file defines first implementation slice",
  "priorities": {
    "music": "high",
    "sfx": "high",
    "voice": "low"
  },
  "styleFamilies": [
    "heroic-sci-fantasy",
    "melancholic-techno-fantasy"
