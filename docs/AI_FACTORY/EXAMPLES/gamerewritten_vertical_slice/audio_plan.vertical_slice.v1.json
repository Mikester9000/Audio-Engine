  "musicDurationPolicy": {
    "note": "See docs/AI_FACTORY/SUBSYSTEMS/MUSIC.md for the canonical music duration table.",
    "majorThemes": "120–300 s (up to 5 minutes); long-form game-ready pieces",
    "gameplayLoops": "60–120 s; loopable at a natural loop point",
    "bossLoops": "90–180 s; longer loops preferred",
    "stingersAndFanfares": "2–12 s; never loopable",
    "ostVariants": "For key BGM loops an _ost variant at 120–300 s may be planned or generated"
  },
  "assetGroups": [
    {
